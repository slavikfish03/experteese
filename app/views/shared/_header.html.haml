%header.border-bottom.bg-white.shadow-sm
  .container
    %nav.d-flex.flex-column.flex-lg-row.justify-content-between.align-items-start.align-items-lg-center.gap-3.py-3{aria: {label: t("shared.header.aria_label")}}
      = link_to root_path, class: "navbar-brand d-flex align-items-center gap-2 fw-semibold text-dark m-0" do
        %i.fa-solid.fa-chart-column.text-accent
        %span= t("app.name")
      .d-flex.flex-column.flex-lg-row.align-items-start.align-items-lg-center.justify-content-between.gap-3.flex-grow-1
        %ul.nav.nav-pills.flex-wrap.gap-2
          %li.nav-item= link_to t("shared.header.home"), root_path, class: "nav-link #{'active' if current_page?(root_path)}"
          %li.nav-item= link_to t("shared.header.work"), work_path, class: "nav-link #{'active' if current_page?(work_path)}"
          %li.nav-item= link_to t("shared.header.about"), about_path, class: "nav-link #{'active' if current_page?(about_path)}"
          %li.nav-item= link_to t("shared.header.help"), help_path, class: "nav-link #{'active' if current_page?(help_path)}"
          %li.nav-item= link_to t("shared.header.contacts"), contacts_path, class: "nav-link #{'active' if current_page?(contacts_path)}"
        .d-flex.flex-wrap.align-items-center.gap-2.small
          .locale-switch.d-flex.align-items-center.gap-1
            = link_to t("shared.header.locale_en"), locale_switch_path(:en), class: "locale-link #{'active' if I18n.locale == :en}"
            = link_to t("shared.header.locale_ru"), locale_switch_path(:ru), class: "locale-link #{'active' if I18n.locale == :ru}"
          - if signed_in?
            = link_to current_user, class: "account-pill text-decoration-none" do
              %i.fa-solid.fa-user.me-1
              = current_user.name
            = button_to logout_path, method: :delete, class: "btn btn-sm btn-outline-secondary" do
              %i.fa-solid.fa-right-from-bracket.me-1
              = t("shared.header.log_out")
          - else
            = link_to login_path, class: "account-pill text-decoration-none" do
              %i.fa-solid.fa-right-to-bracket.me-1
              = t("shared.header.log_in")
            = link_to signup_path, class: "account-pill text-decoration-none" do
              %i.fa-solid.fa-user-plus.me-1
              = t("shared.header.sign_up")
