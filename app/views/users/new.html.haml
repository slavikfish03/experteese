- content_for :title, t(".title")

.page-header.mb-4
  %span.section-kicker= t(".kicker")
  %h1.h2.mb-2= t(".heading")
  %p.text-secondary.mb-0= t(".lead")

.row.justify-content-center
  .col-lg-7
    .content-band
      = form_with model: @user, local: true do |f|
        - if @user.errors.any?
          .alert.alert-warning
            %strong= t(".errors_heading", count: @user.errors.count)
            %ul.mb-0.mt-2
              - @user.errors.full_messages.each do |message|
                %li= message

        .mb-3
          = f.label :name, class: "form-label fw-semibold"
          = f.text_field :name, class: "form-control", required: true
        .mb-3
          = f.label :email, class: "form-label fw-semibold"
          = f.email_field :email, class: "form-control", required: true
        .mb-3
          = f.label :password, class: "form-label fw-semibold"
          = f.password_field :password, class: "form-control", required: true
        .mb-4
          = f.label :password_confirmation, t(".confirm_password"), class: "form-label fw-semibold"
          = f.password_field :password_confirmation, class: "form-control", required: true

        = f.submit t(".submit"), class: "btn btn-accent"
