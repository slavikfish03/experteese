- content_for :title, t(".title")

.hero-surface.mb-4.mb-lg-5
  .row.g-4.align-items-center
    .col-lg-7
      %span.section-kicker= t(".kicker")
      %h1.display-6.fw-semibold.mb-3= t(".heading")
      %p.lead.text-secondary.mb-4= t(".lead")
      .d-flex.flex-wrap.gap-2
        = link_to about_path, class: "btn btn-accent" do
          %i.fa-solid.fa-circle-info.me-2
          = t(".overview")
        = link_to help_path, class: "btn btn-outline-secondary" do
          %i.fa-solid.fa-book.me-2
          = t(".notes")
    .col-lg-5
      .summary-panel
        %h2.h5.mb-3= t(".status_heading")
        %ul.summary-list
          - %i[controller layout assets navigation].each do |item|
            - text = t(".status_items.#{item}")
            - if text.present?
              %li= text

.row.g-4
  .col-lg-6
    %section.content-band.h-100
      %h2.h5.mb-3= t(".modules_heading")
      %ul.stacked-list
        - %i[work auth ajax locale].each do |item|
          - text = t(".module_items.#{item}")
          - if text.present?
            %li= text
  .col-lg-6
    %section.content-band.h-100
      %h2.h5.mb-3= t(".baseline_heading")
      %dl.meta-grid.mb-0
        %div
          %dt= t(".framework")
          %dd Ruby on Rails 8.1.x
        %div
          %dt= t(".database")
          %dd PostgreSQL 18
        %div
          %dt= t(".markup")
          %dd Haml
        %div
          %dt= t(".styling")
          %dd Sass + Bootstrap + Font Awesome
